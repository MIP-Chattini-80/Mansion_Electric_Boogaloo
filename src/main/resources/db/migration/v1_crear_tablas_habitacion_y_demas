CREATE TABLE objetos (
    id_instancia INT AUTO_INCREMENT PRIMARY KEY,
    id_habitacion INT NOT NULL,
    id_objeto INT NOT NULL,
    cantidad INT NOT NULL,
    estado VARCHAR(50) NOT NULL,
